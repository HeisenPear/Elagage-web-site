---
/**
 * Page service : Élagage d'arbres
 * SEO cible : "élagage arbre Tours" / "élagueur Tours"
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig, getPhoneLink } from '@/data/siteConfig';
import { getServiceSchema, getFAQSchema, getBreadcrumbSchema, combineSchemas } from '@/utils/schemas';

const pageTitle = "Élagage d'arbres à Tours (37) – Élagueur professionnel certifié";
const pageDescription = "Élagage professionnel à Tours et Indre-et-Loire. Élagage raisonné, sanitaire, de sécurité. Élagueur grimpeur certifié, assuré 8M€. Crédit d'impôt -50%. Devis gratuit 24h.";

const faqs = [
  {
    question: "Quelle est la meilleure période pour élaguer un arbre ?",
    answer: "La période idéale est l'hiver (novembre à mars), quand l'arbre est en repos végétatif. Les cicatrices se forment mieux et les risques de maladies sont réduits. Certains arbres comme les cerisiers se taillent mieux en été. Nous vous conseillons selon les espèces présentes dans votre jardin.",
  },
  {
    question: "Combien coûte un élagage d'arbre à Tours ?",
    answer: "Le prix varie selon la hauteur, l'essence et l'accessibilité : 200-400€ pour un arbre de 5-10m, 400-800€ pour 10-15m, sur devis pour les grands sujets. Avec le crédit d'impôt de 50%, votre coût réel est divisé par deux. Devis gratuit sous 24h.",
  },
  {
    question: "Faut-il une autorisation pour élaguer un arbre ?",
    answer: "Sur votre propriété, l'élagage est libre. Toutefois, en zone protégée, classement au PLU, ou pour les arbres remarquables, une déclaration préalable peut être requise. Nous vérifions votre situation et vous accompagnons dans les démarches si nécessaire.",
  },
  {
    question: "Quelle différence entre élagage raisonné et élagage de sécurité ?",
    answer: "L'élagage raisonné respecte la biologie de l'arbre : on enlève le minimum pour conserver sa forme naturelle et sa vigueur. L'élagage de sécurité vise à supprimer les branches mortes, malades ou menaçantes pour les personnes et les biens. Les deux approches se complètent.",
  },
  {
    question: "Que faites-vous des branches après l'élagage ?",
    answer: "Nous évacuons systématiquement toutes les branches et déchets verts. Sur demande, nous pouvons broyer les branches sur place pour constituer un paillage naturel pour votre jardin. Le chantier est laissé propre à notre départ.",
  },
];

const schema = combineSchemas(
  getServiceSchema("Élagage d'arbres", pageDescription, "elagage-arbres"),
  getFAQSchema(faqs),
  getBreadcrumbSchema([
    { name: "Accueil", url: "/" },
    { name: "Services", url: "/#services" },
    { name: "Élagage d'arbres", url: "/services/elagage-arbres" },
  ])
);
---

<BaseLayout title={pageTitle} description={pageDescription} schema={schema}>

  <!-- HERO -->
  <section class="pt-24 md:pt-32 pb-16 bg-gradient-to-br from-primary-900 to-primary text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute top-10 right-10 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
    </div>
    <div class="container-custom relative z-10">
      <nav class="flex items-center gap-2 text-sm text-white/60 mb-8">
        <a href="/" class="hover:text-accent transition-colors">Accueil</a>
        <span>/</span>
        <a href="/#services" class="hover:text-accent transition-colors">Services</a>
        <span>/</span>
        <span class="text-white">Élagage d'arbres</span>
      </nav>

      <div class="max-w-4xl">
        <span class="inline-block px-4 py-1.5 bg-accent/20 text-accent font-semibold rounded-full text-sm uppercase tracking-wider mb-4">
          Service n°1
        </span>
        <h1 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-tight">
          Élagage d'arbres à Tours (37)<br/>
          <span class="text-accent">Élagueur grimpeur certifié</span>
        </h1>
        <p class="text-lg md:text-xl text-white/85 mb-8 max-w-3xl">
          Élagage raisonné, sanitaire ou de sécurité pour tous types d'arbres. Intervenant en Indre-et-Loire depuis plus de 10 ans. Assuré RC Pro 8 000 000€.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={getPhoneLink()} class="btn-primary inline-flex text-lg justify-center">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Appeler : {siteConfig.business.phoneDisplay}
          </a>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 border-2 border-white text-white font-bold rounded-xl hover:bg-white hover:text-primary transition-all">
            Devis gratuit en ligne
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- INTRO SEO -->
  <section class="py-14 md:py-20 bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-3 gap-6 mb-12">
          {[
            { label: "Certifié CS Arboriste", icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", color: "text-accent" },
            { label: "Assuré RC Pro 8M€", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", color: "text-blue-600" },
            { label: "Crédit d'impôt -50%", icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z", color: "text-secondary" },
          ].map(b => (
            <div class="flex items-center gap-3 bg-neutral-cream rounded-xl p-4">
              <svg class={`w-7 h-7 flex-shrink-0 ${b.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={b.icon}/></svg>
              <span class="font-semibold text-primary">{b.label}</span>
            </div>
          ))}
        </div>

        <h2 class="text-2xl md:text-3xl font-display font-bold text-primary mb-5">
          Élagage professionnel à Tours et en Indre-et-Loire
        </h2>
        <div class="space-y-4 text-neutral-gray leading-relaxed text-base md:text-lg">
          <p>
            L'<strong>élagage d'un arbre</strong> est une intervention délicate qui demande une expertise technique solide et une parfaite connaissance de la biologie végétale. Chez <strong>Élagage Abattage 37</strong>, nous réalisons des <strong>élaguages professionnels à Tours</strong> et dans tout le département 37 depuis plus de 10 ans.
          </p>
          <p>
            Notre <strong>élagueur grimpeur certifié</strong> intervient sur tous les types d'arbres : chênes, platanes, tilleuls, frênes, érables, arbres fruitiers… Qu'il s'agisse d'un <strong>élagage raisonné</strong> pour conserver la forme naturelle de votre arbre, d'un <strong>élagage sanitaire</strong> pour supprimer les branches mortes ou malades, ou d'un <strong>élagage de sécurité</strong> pour protéger vos biens, nous adaptons notre intervention à vos besoins.
          </p>
          <p>
            Basée à <strong>Joué-lès-Tours</strong>, notre équipe intervient rapidement dans toute l'agglomération tourangelle : <strong>Tours centre</strong>, <strong>Saint-Cyr-sur-Loire</strong>, <strong>Amboise</strong>, <strong>Montlouis-sur-Loire</strong>, <strong>Chambray-lès-Tours</strong>, <strong>La Riche</strong> et toutes les communes du 37.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- TYPES D'ÉLAGAGE -->
  <section class="py-14 md:py-20 bg-neutral-cream">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-2xl md:text-4xl font-display font-bold text-primary mb-4">
            Nos techniques d'élagage à Tours
          </h2>
          <p class="text-lg text-neutral-gray">Une approche adaptée à chaque arbre et chaque situation</p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {[
            {
              title: "Élagage raisonné",
              subtitle: "Respect de la biologie de l'arbre",
              desc: "L'élagage raisonné consiste à intervenir le moins possible tout en respectant la silhouette naturelle de l'arbre. On retire uniquement les branches qui nuisent à l'équilibre (branches croisées, gourmands, drageons). Cette approche garantit la longévité de l'arbre et limite les repousses anarchiques.",
              points: ["Taille minimale et ciblée", "Respect de l'architecture naturelle", "Préservation de la vigueur", "Cicatrisation optimale"],
            },
            {
              title: "Élagage sanitaire",
              subtitle: "Santé et prévention",
              desc: "L'élagage sanitaire supprime les branches mortes, malades, attaquées par des champignons ou des parasites. Il permet de stopper la propagation des maladies et de redonner vigueur à l'arbre. Un diagnostic phytosanitaire peut être réalisé en amont pour évaluer l'état de santé.",
              points: ["Suppression des branches mortes", "Élimination des foyers de maladies", "Diagnostic phytosanitaire", "Traitement préventif possible"],
            },
            {
              title: "Élagage de sécurité",
              subtitle: "Protection des personnes et des biens",
              desc: "L'élagage de sécurité intervient quand des branches menacent une maison, une ligne électrique, un chemin ou une personne. Nous réalisons une évaluation du risque et procédons à l'ablation des branches dangereuses avec des techniques de grimpe sécurisées.",
              points: ["Suppression branches dangereuses", "Travail en hauteur sécurisé", "Intervention d'urgence possible", "Coordination avec ERDF si nécessaire"],
            },
            {
              title: "Élagage en hauteur / grimpe",
              subtitle: "Technique arboriste-élagueur",
              desc: "Pour les grands arbres ou les zones d'accès difficile, nos élagueurs grimpeurs utilisent des techniques de grimpe sur cordes (SRT/DdRT). Cette méthode préserve l'arbre (pas d'appui sur les branches) et permet d'intervenir dans des espaces contraints inaccessibles à une nacelle.",
              points: ["Grimpe sur cordes certifiée", "Sans dommage pour l'arbre", "Accès zones contraintes", "Matériel Stihl professionnel"],
            },
          ].map(item => (
            <article class="bg-white rounded-2xl p-6 md:p-8 shadow-soft border border-neutral-200 hover:border-accent/30 transition-colors">
              <h3 class="text-xl font-display font-bold text-primary mb-1">{item.title}</h3>
              <p class="text-sm font-semibold text-accent uppercase tracking-wide mb-3">{item.subtitle}</p>
              <p class="text-neutral-gray text-sm leading-relaxed mb-5">{item.desc}</p>
              <ul class="space-y-2">
                {item.points.map(p => (
                  <li class="flex items-center gap-2 text-sm text-neutral-gray">
                    <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    {p}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ARBRES TRAITÉS + TARIFS -->
  <section class="py-14 md:py-20 bg-white">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-10 items-start">

        <div>
          <h2 class="text-2xl md:text-3xl font-display font-bold text-primary mb-6">
            Arbres élagués à Tours
          </h2>
          <p class="text-neutral-gray mb-5">Nous intervenons sur toutes les essences arborées, ornementales ou fruitières :</p>
          <div class="grid grid-cols-2 gap-2">
            {["Chênes", "Platanes", "Tilleuls", "Frênes", "Érables", "Châtaigniers", "Peupliers", "Robiniers", "Thuyas", "Acacias", "Conifères", "Cyprès", "Pommiers", "Poiriers", "Cerisiers", "Pruniers"].map(tree => (
              <span class="flex items-center gap-2 text-sm text-neutral-gray py-1.5 px-3 bg-neutral-cream rounded-lg">
                <span class="text-accent text-xs">✓</span> {tree}
              </span>
            ))}
          </div>
          <p class="text-sm text-neutral-gray mt-4">
            Un autre arbre ? <a href={getPhoneLink()} class="text-accent font-semibold hover:underline">Appelez-nous</a>, nous intervenons sur toutes les espèces.
          </p>
        </div>

        <div>
          <h2 class="text-2xl md:text-3xl font-display font-bold text-primary mb-6">
            Tarifs élagage Tours 2025
          </h2>
          <div class="bg-neutral-cream rounded-2xl p-6 border border-neutral-200">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-neutral-300">
                  <th class="text-left pb-3 text-primary font-bold">Hauteur arbre</th>
                  <th class="text-right pb-3 text-primary font-bold">Prix indicatif</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-200">
                {[
                  ["< 5m (petit)", "150 – 300 €"],
                  ["5 – 10m (moyen)", "300 – 500 €"],
                  ["10 – 15m (grand)", "500 – 800 €"],
                  ["15 – 20m (très grand)", "800 – 1 200 €"],
                  ["> 20m", "Sur devis"],
                ].map(([h, p]) => (
                  <tr>
                    <td class="py-2.5 text-neutral-gray">{h}</td>
                    <td class="py-2.5 text-right font-semibold text-primary">{p}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            <div class="mt-5 p-4 bg-accent/10 rounded-xl border border-accent/20">
              <p class="text-sm font-bold text-accent mb-1">Crédit d'impôt -50%</p>
              <p class="text-xs text-neutral-gray">Ces tarifs sont divisés par 2 grâce au crédit d'impôt services à la personne (plafond 2 500€/an). Attestation fiscale fournie.</p>
            </div>
          </div>
          <a href="/blog/prix-elagage-arbre-tarifs-tours" class="inline-flex items-center gap-1.5 text-sm text-accent font-semibold mt-4 hover:underline">
            Voir le guide complet des prix d'élagage →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- POURQUOI NOUS -->
  <section class="py-14 md:py-20 bg-primary text-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto text-center mb-12">
        <h2 class="text-2xl md:text-4xl font-display font-bold mb-4">
          Pourquoi choisir Élagage Abattage 37 ?
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto">
        {[
          { title: "Certifié CS Arboriste", desc: "Formation professionnelle + 10 ans d'expérience sur le terrain en Indre-et-Loire." },
          { title: "Assuré 8 000 000€", desc: "RC Pro complète couvrant tous les chantiers. Devis et attestation fournis avant intervention." },
          { title: "Crédit d'impôt -50%", desc: "50% de réduction fiscale sur vos travaux. Attestation annuelle fournie automatiquement." },
          { title: "Devis gratuit 24h", desc: "Réponse sous 24h, déplacement sans engagement pour évaluer votre chantier sur place." },
        ].map(item => (
          <div class="bg-white/10 rounded-2xl p-6 border border-white/10">
            <h3 class="font-bold text-lg mb-2">{item.title}</h3>
            <p class="text-sm text-white/75 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ZONES D'INTERVENTION -->
  <section class="py-14 md:py-20 bg-white">
    <div class="container-custom max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-primary mb-4">
        Zone d'intervention pour l'élagage
      </h2>
      <p class="text-neutral-gray mb-6">
        Nous réalisons des <strong>élaguages d'arbres</strong> dans tout le département <strong>Indre-et-Loire (37)</strong>, dans un rayon de 50km autour de Tours :
      </p>
      <div class="flex flex-wrap gap-2 mb-8">
        {[
          { name: "Tours", slug: "elagueur-tours" },
          { name: "Joué-lès-Tours", slug: "elagueur-joue-les-tours" },
          { name: "Amboise", slug: "elagueur-amboise" },
          { name: "Saint-Cyr-sur-Loire", slug: "elagueur-saint-cyr-sur-loire" },
          { name: "Montlouis-sur-Loire", slug: "elagueur-montlouis-sur-loire" },
        ].map(city => (
          <a href={`/zones/${city.slug}`} class="inline-flex items-center gap-1.5 px-3 py-2 bg-neutral-cream text-primary hover:bg-accent hover:text-white border border-neutral-200 hover:border-accent rounded-lg text-sm font-medium transition-all">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            Élagage {city.name}
          </a>
        ))}
        <a href="/zones" class="inline-flex items-center gap-1.5 px-3 py-2 bg-accent/10 text-accent hover:bg-accent hover:text-white border border-accent/30 rounded-lg text-sm font-semibold transition-all">
          Voir toutes les zones →
        </a>
      </div>

      <!-- Maillage interne services -->
      <div class="border-t border-neutral-200 pt-8">
        <h3 class="font-bold text-primary mb-4">Nos autres services</h3>
        <div class="flex flex-wrap gap-3">
          {[
            { name: "Abattage d'arbres", slug: "abattage-arbres" },
            { name: "Dessouchage", slug: "dessouchage-arbres" },
            { name: "Taille de haies", slug: "taille-haies" },
            { name: "Entretien espaces verts", slug: "entretien-espaces-verts" },
            { name: "Élagage fruitiers", slug: "elagage-fruitiers" },
          ].map(s => (
            <a href={`/services/${s.slug}`} class="text-sm text-accent hover:underline font-medium">
              → {s.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-14 md:py-20 bg-neutral-cream">
    <div class="container-custom max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-4xl font-display font-bold text-primary">
          Questions fréquentes sur l'élagage
        </h2>
      </div>
      <div class="space-y-4">
        {faqs.map((item, i) => (
          <details class="group bg-white rounded-xl border border-neutral-200 hover:border-accent/30 transition-colors overflow-hidden">
            <summary class="flex items-center justify-between p-5 cursor-pointer list-none font-bold text-primary hover:text-accent transition-colors">
              <span class="flex items-center gap-3 text-base">
                <span class="w-7 h-7 bg-accent/10 text-accent rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">{i + 1}</span>
                {item.question}
              </span>
              <svg class="w-5 h-5 flex-shrink-0 text-accent transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 pt-4 text-neutral-gray text-sm leading-relaxed border-t border-neutral-200">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINALE -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-primary-900 to-primary text-white text-center">
    <div class="container-custom max-w-2xl mx-auto">
      <div class="flex justify-center text-yellow-400 text-xl mb-4">★★★★★</div>
      <h2 class="text-2xl md:text-4xl font-display font-bold mb-4">
        Besoin d'un élagueur à Tours ?
      </h2>
      <p class="text-white/75 mb-8">Devis gratuit · Intervention sous 48h · Crédit d'impôt -50%</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={getPhoneLink()} class="btn-primary inline-flex justify-center text-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {siteConfig.business.phoneDisplay}
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 border-2 border-white text-white font-bold rounded-xl hover:bg-white hover:text-primary transition-all">
          Devis en ligne
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
