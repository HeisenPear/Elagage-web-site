---
/**
 * Page service : Élagage arbres fruitiers
 * SEO cible : "taille arbre fruitier Tours" / "élagage fruitier 37"
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig, getPhoneLink } from '@/data/siteConfig';
import { getServiceSchema, getFAQSchema, getBreadcrumbSchema, combineSchemas } from '@/utils/schemas';

const pageTitle = "Élagage arbres fruitiers à Tours (37) – Taille professionnelle";
const pageDescription = "Taille d'arbres fruitiers à Tours et Indre-et-Loire. Pommiers, poiriers, cerisiers, pruniers, pêchers. Meilleure récolte garantie. Devis gratuit 24h.";

const faqs = [
  {
    question: "Quand faut-il tailler les arbres fruitiers ?",
    answer: "La période de taille varie selon l'essence : les arbres à pépins (pommiers, poiriers) se taillent en hiver (décembre-mars) quand ils sont en repos végétatif. Les arbres à noyaux (cerisiers, pruniers, pêchers) se taillent de préférence en été (juin-août) pour éviter les maladies cryptogamiques. Nous adaptons notre intervention à chaque espèce.",
  },
  {
    question: "La taille améliore-t-elle la production de fruits ?",
    answer: "Oui, une taille bien réalisée améliore significativement la production : meilleure aération du feuillage, luminosité optimale pour la fructification, suppression des branches épuisées. Un pommier bien taillé produit de plus gros fruits, en meilleure santé, et vit plus longtemps.",
  },
  {
    question: "Que faire d'un vieux verger abandonné ?",
    answer: "Un verger abandonné peut être réhabilité progressivement sur 2 à 3 ans. On commence par supprimer les bois morts et malades, puis on réduit progressivement le volume pour ne pas stresser les arbres. Nous réalisons un diagnostic de votre verger et vous proposons un plan de réhabilitation.",
  },
];

const schema = combineSchemas(
  getServiceSchema("Élagage d'arbres fruitiers", pageDescription, "elagage-fruitiers"),
  getFAQSchema(faqs),
  getBreadcrumbSchema([
    { name: "Accueil", url: "/" },
    { name: "Services", url: "/#services" },
    { name: "Élagage fruitiers", url: "/services/elagage-fruitiers" },
  ])
);
---

<BaseLayout title={pageTitle} description={pageDescription} schema={schema}>

  <section class="pt-24 md:pt-32 pb-16 bg-gradient-to-br from-rose-900 to-rose-700 text-white">
    <div class="container-custom">
      <nav class="flex items-center gap-2 text-sm text-white/60 mb-8">
        <a href="/" class="hover:text-white/90">Accueil</a>
        <span>/</span>
        <a href="/#services" class="hover:text-white/90">Services</a>
        <span>/</span>
        <span class="text-white">Élagage fruitiers</span>
      </nav>
      <div class="max-w-4xl">
        <h1 class="text-3xl md:text-5xl font-display font-bold mb-6 leading-tight">
          Élagage arbres fruitiers à Tours (37)<br/>
          <span class="text-rose-300">Optimisez votre récolte</span>
        </h1>
        <p class="text-lg md:text-xl text-white/85 mb-8 max-w-3xl">
          Taille spécialisée d'arbres fruitiers pour améliorer la production, la santé et la longévité. Pommiers, poiriers, cerisiers, pruniers, pêchers en Touraine.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={getPhoneLink()} class="inline-flex items-center justify-center gap-3 px-7 py-4 bg-white text-rose-800 font-bold text-lg rounded-xl hover:bg-rose-50 transition-all shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {siteConfig.business.phoneDisplay}
          </a>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 border-2 border-white text-white font-bold rounded-xl hover:bg-white hover:text-rose-800 transition-all">
            Devis gratuit
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 md:py-20 bg-white">
    <div class="container-custom max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-primary mb-6">
        Taille fruitiers : une expertise spécifique
      </h2>
      <div class="space-y-4 text-neutral-gray leading-relaxed">
        <p>
          La <strong>taille des arbres fruitiers</strong> est une discipline à part entière qui requiert une connaissance approfondie de la biologie et des cycles végétatifs de chaque espèce. Contrairement à l'élagage d'arbres d'ornement, la taille fruitière vise à <strong>optimiser la production</strong> en équilibrant la vigueur végétative et la fructification.
        </p>
        <p>
          Chez <strong>Élagage Abattage 37</strong>, nous intervenons sur tous vos <strong>arbres fruitiers à Tours et en Touraine</strong> : pommiers anciens des vergers ligériens, poiriers, cerisiers, pruniers, pêchers, abricotiers, cognassiers, noisetiers. Nous adaptons notre technique à l'âge, la forme et l'état de santé de chaque arbre.
        </p>
      </div>
    </div>
  </section>

  <section class="py-14 md:py-20 bg-neutral-cream">
    <div class="container-custom max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-4xl font-display font-bold text-primary mb-4">Fruitiers traités à Tours</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { name: "Pommiers", period: "Décembre – Mars", type: "À pépins", desc: "Taille de fructification, suppression vieux bois, équilibrage de la charpente. Spécialité de la Touraine." },
          { name: "Poiriers", period: "Décembre – Mars", type: "À pépins", desc: "Taille des rameaux fructifères, formation en palmette ou gobelet. Amélioration calibre des fruits." },
          { name: "Cerisiers", period: "Juin – Août", type: "À noyaux", desc: "Taille légère en été pour éviter la maladie des taches. Suppression des branches mortes uniquement en hiver." },
          { name: "Pruniers", period: "Juin – Août", type: "À noyaux", desc: "Taille d'été pour les Reine-Claude et Mirabelles. Aération du houppier pour lutter contre les champignons." },
          { name: "Pêchers / Nectariniers", period: "Février – Mars", type: "À noyaux", desc: "Taille courte et annuelle indispensable pour renouveler les rameaux fructifères. Technique précise." },
          { name: "Vieux vergers", period: "Selon état", type: "Réhabilitation", desc: "Diagnostic + plan de réhabilitation progressive sur 2-3 ans pour les vergers anciens abandonnés." },
        ].map(item => (
          <article class="bg-white rounded-2xl p-5 shadow-soft border border-neutral-200">
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-bold text-primary">{item.name}</h3>
              <span class="text-xs font-semibold px-2 py-0.5 bg-rose-100 text-rose-700 rounded">{item.type}</span>
            </div>
            <p class="text-xs text-accent font-semibold mb-2">Taille : {item.period}</p>
            <p class="text-sm text-neutral-gray leading-relaxed">{item.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-10 bg-white border-t border-neutral-200">
    <div class="container-custom max-w-4xl mx-auto">
      <h3 class="font-bold text-primary mb-3 text-sm">Nos autres services</h3>
      <div class="flex flex-wrap gap-3">
        {[
          { name: "Élagage d'arbres", slug: "elagage-arbres" },
          { name: "Abattage d'arbres", slug: "abattage-arbres" },
          { name: "Dessouchage", slug: "dessouchage-arbres" },
          { name: "Taille de haies", slug: "taille-haies" },
          { name: "Entretien espaces verts", slug: "entretien-espaces-verts" },
        ].map(s => (
          <a href={`/services/${s.slug}`} class="text-sm text-accent hover:underline font-medium">→ {s.name}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 md:py-20 bg-neutral-cream">
    <div class="container-custom max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-4xl font-display font-bold text-primary">FAQ élagage fruitiers</h2>
      </div>
      <div class="space-y-4">
        {faqs.map((item, i) => (
          <details class="group bg-white rounded-xl border border-neutral-200 hover:border-accent/30 transition-colors overflow-hidden">
            <summary class="flex items-center justify-between p-5 cursor-pointer list-none font-bold text-primary hover:text-accent transition-colors">
              <span class="flex items-center gap-3 text-base">
                <span class="w-7 h-7 bg-accent/10 text-accent rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">{i + 1}</span>
                {item.question}
              </span>
              <svg class="w-5 h-5 flex-shrink-0 text-accent transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 pt-4 text-neutral-gray text-sm leading-relaxed border-t border-neutral-200">{item.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-rose-900 to-rose-700 text-white text-center">
    <div class="container-custom max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-4xl font-display font-bold mb-4">Taille fruitiers à Tours ?</h2>
      <p class="text-white/75 mb-8">Devis gratuit · Taille adaptée à chaque essence · Crédit d'impôt -50%</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={getPhoneLink()} class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-rose-800 font-bold text-lg rounded-xl hover:bg-rose-50 transition-all shadow-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {siteConfig.business.phoneDisplay}
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 border-2 border-white text-white font-bold rounded-xl hover:bg-white hover:text-rose-800 transition-all">
          Devis en ligne
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
